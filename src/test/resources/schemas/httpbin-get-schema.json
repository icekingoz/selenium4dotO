{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["args", "headers", "origin", "url"],
  "properties": {
    "args":    { "type": "object" },
    "headers": { "type": "object", "required": ["Host", "User-Agent"] },
    "origin":  { "type": "string" },
    "url":     { "type": "string", "format": "uri" }
  }
}
